<!DOCTYPE html>
<html>
<head>
  <title>User Repurchase</title>
</head>
<body>

<h2>Repurchase Page</h2>

<p>User ID: <span id="userId"></span></p>

<button onclick="repurchase()">Repurchase</button>

<!-- ✅ CORE FIRST -->
<script src="CORE_system.js"></script>

<script>

// ================= INIT CORE =================
initCoreSystem();

// ================= GET USER FROM URL =================
let params = new URLSearchParams(window.location.search);
let userId = params.get("user");

document.getElementById("userId").innerText = userId || "N/A";

// ================= 🔥 REPURCHASE INCOME =================
function payRepurchaseIncome(buyerId) {

  let users = getUsers();
  let buyer = getUserById(buyerId);

  if (!buyer) return;

  let current = buyer;
  let level = 1;

  while (current && current.introducerId && level <= 20) {

    let parent = getUserById(current.introducerId);
    if (!parent) break;

    // 💰 Flat income
    let income = 20;

    parent.wallet = (parent.wallet || 0) + income;

    current = parent;
    level++;
  }

  saveUsers(users);
}

// ================= ACTION =================
function repurchase() {

  if (!userId) {
    alert("Invalid user");
    return;
  }

  payRepurchaseIncome(userId);

  alert("Repurchase Successful! Income Distributed ✅");

  window.location.href = "user_dashboard.html";
}

</script>

</body>
</html>
